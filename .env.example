# Database
DATABASE_URL=sqlite+aiosqlite:///./archaeological_catalog.db

# JWT/Security
SECRET_KEY=change-me
CSRF_SECRET_KEY=change-me
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# MinIO Profile
MINIO_CONFIG_PROFILE=local

# Local MinIO (Docker Compose)
# For non-docker local usage, set MINIO_LOCAL_URL=http://localhost:9000
MINIO_LOCAL_URL=http://minio:9000
MINIO_LOCAL_ACCESS_KEY=minioadmin
MINIO_LOCAL_SECRET_KEY=minioadmin
MINIO_LOCAL_BUCKET=archaeological-photos
MINIO_LOCAL_SECURE=false

# Remote MinIO (optional)
MINIO_REMOTE_URL=http://192.168.0.152:9000
MINIO_REMOTE_ACCESS_KEY=
MINIO_REMOTE_SECRET_KEY=
MINIO_REMOTE_BUCKET=archaeological-photos
MINIO_REMOTE_SECURE=false
