      "section_icon": "fa-check-square",
      "fields": [
        {
          "pdf_label": "POSITIVA / NEGATIVA",
          "model_key": "tipo",
          "type": "radio_group",
          "options": [
            {
              "label": "Positiva (accumulo)",
              "value": "positiva"
            },
            {
              "label": "Negativa (taglio)",
              "value": "negativa"
            }
          ],
          "width": "col-span-3"
        }
      ]
    },
