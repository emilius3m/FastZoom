{
  "form_sections": [
    {
      "section_id": "intestazione",
      "section_label": "INTESTAZIONE",
      "section_icon": "fa-list",
      "fields": [
        {
          "pdf_label": "US",
          "model_key": "us_code",
          "type": "text",
          "hint": "Codice identificativo (es. US001)",
          "required": true,
          "width": "col-span-1"
        },
        {
          "pdf_label": "ENTE RESPONSABILE",
          "model_key": "ente_responsabile",
          "type": "text",
          "required": false,
          "width": "col-span-2"
        },
        {
          "pdf_label": "ANNO",
          "model_key": "anno",
          "type": "number",
          "required": false,
          "width": "col-span-1"
        }
      ]
    },
    {
      "section_id": "amministrativi",
      "section_label": "DATI AMMINISTRATIVI",
      "section_icon": "fa-file",
      "fields": [
        {
          "pdf_label": "UFFICIO MiC COMPETENTE PER TUTELA",
          "model_key": "ufficio_mic",
          "type": "text",
          "width": "col-span-2"
