            {
              "label": "Media",
              "value": "media"
            },
            {
              "label": "Friabile",
              "value": "friabile"
            },
            {
              "label": "Molto friabile",
              "value": "molto_friabile"
            },
            {
              "label": "Sciolta",
              "value": "sciolta"
